{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Univers Ark Developer",
  "version": "0.1.0",
  "identifier": "dev.univers.arkdeveloper",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Univers Ark Developer",
        "width": 1460,
        "height": 940,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
