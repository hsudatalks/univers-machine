{
  "selectedTargetId": "mechanism-dev::automation-dev",
  "targets": [
    {
      "id": "local",
      "label": "Local",
      "host": "localhost",
      "description": "Local shell with direct development and preview surfaces on ports 3432 and 4173.",
      "terminalCommand": "exec /bin/zsh -l",
      "notes": [],
      "surfaces": [
        {
          "id": "development",
          "label": "Development",
          "tunnelCommand": "",
          "localUrl": "http://127.0.0.1:3432/",
          "remoteUrl": "http://127.0.0.1:3432/"
        },
        {
          "id": "preview",
          "label": "Preview",
          "tunnelCommand": "",
          "localUrl": "http://127.0.0.1:4173/",
          "remoteUrl": "http://127.0.0.1:4173/"
        }
      ]
    }
  ],
  "remoteServers": [
    {
      "id": "mechanism-dev",
      "label": "Mechanism",
      "host": "mechanism-dev",
      "description": "Mechanism development server hosting LXD development containers.",
      "discoveryCommand": "ssh mechanism-dev 'lxc list --format csv -c ns4'",
      "sshUser": "ubuntu",
      "sshOptions": "-o StrictHostKeyChecking=accept-new",
      "targetHostTemplate": "{serverHost}",
      "targetDescriptionTemplate": "{containerLabel} development container routed through {serverLabel}.",
      "notes": [
        "SSH target: {sshUser}@{containerIp} via {serverHost}.",
        "Development maps the container's 3432 port for the live app surface.",
        "Preview maps the container's 4173 port for the production-like preview build.",
        "The desktop app allocates a free local browser port in the 43000-43999 range for each surface and expands {localPort} before starting the tunnel."
      ],
      "surfaces": [
        {
          "id": "development",
          "label": "Development",
          "tunnelCommand": "ssh {sshOptions} -NT -L {localPort}:127.0.0.1:3432 -J {serverHost} {sshUser}@{containerIp}",
          "viteHmrTunnelCommand": "ssh {sshOptions} -NT -L {localPort}:127.0.0.1:3433 -J {serverHost} {sshUser}@{containerIp}",
          "localUrl": "http://127.0.0.1:{localPort}/",
          "remoteUrl": "http://127.0.0.1:3432/"
        },
        {
          "id": "preview",
          "label": "Preview",
          "tunnelCommand": "ssh {sshOptions} -NT -L {localPort}:127.0.0.1:4173 -J {serverHost} {sshUser}@{containerIp}",
          "localUrl": "http://127.0.0.1:{localPort}/",
          "remoteUrl": "http://127.0.0.1:4173/"
        }
      ]
    }
  ]
}
