    {
      "id": "local",
      "label": "Local",
      "host": "localhost",
      "description": "Local shell with direct development and preview surfaces on ports 3432 and 4173.",
      "terminalCommand": "exec /bin/zsh -l",
      "notes": [],
      "surfaces": [
        {
          "id": "development",
          "label": "Development",
          "tunnelCommand": "",
          "localUrl": "http://127.0.0.1:3432/",
          "remoteUrl": "http://127.0.0.1:3432/"
        },
        {
          "id": "preview",
          "label": "Preview",
          "tunnelCommand": "",
          "localUrl": "http://127.0.0.1:4173/",
          "remoteUrl": "http://127.0.0.1:4173/"
        }
      ]
    }
  ],
  "remoteServers": [
    {
      "id": "app-dev",
      "label": "agent",
      "host": "app-dev",
      "description": "App development host running OrbStack Ubuntu machines.",
      "discoveryCommand": "ssh app-dev 'python3 - <<'\"'\"'PY'\"'\"'\nimport subprocess\nlines = subprocess.check_output([\"orb\", \"list\"], text=True).splitlines()\nfor line in lines:\n    line = line.strip()\n    if not line:\n        continue\n    parts = line.split()\n    name = parts[0]\n    state = parts[1]\n    ip = parts[-1]\n    if state == \"running\" and name.endswith(\"-dev\"):\n        print(f\"{name},RUNNING,{ip} (eth0)\")\nPY'",
      "sshUser": "davidxu",
      "sshOptions": "-o StrictHostKeyChecking=accept-new",
      "targetHostTemplate": "{serverHost}",
      "targetDescriptionTemplate": "{containerLabel} OrbStack machine routed through {serverLabel}.",
      "notes": [
        "SSH target: {sshUser}@{containerIp} via {serverHost}.",
        "This server uses OrbStack machines instead of LXD containers.",
        "Development maps the machine's 3432 port for the live app surface.",
        "Preview maps the machine's 4173 port for the production-like preview build.",
        "The desktop app uses a per-container HostKeyAlias to avoid known_hosts collisions across overlapping private IP ranges."
      ],
      "surfaces": [
        {
          "id": "development",
          "label": "Development",
          "tunnelCommand": "ssh {sshOptions} -NT -L {localPort}:127.0.0.1:3432 -J {serverHost} {sshUser}@{containerIp}",
          "viteHmrTunnelCommand": "ssh {sshOptions} -NT -L {localPort}:127.0.0.1:3433 -J {serverHost} {sshUser}@{containerIp}",
          "localUrl": "http://127.0.0.1:{localPort}/",
          "remoteUrl": "http://127.0.0.1:3432/"
        },
        {
          "id": "preview",
          "label": "Preview",
          "tunnelCommand": "ssh {sshOptions} -NT -L {localPort}:127.0.0.1:4173 -J {serverHost} {sshUser}@{containerIp}",
          "localUrl": "http://127.0.0.1:{localPort}/",
          "remoteUrl": "http://127.0.0.1:4173/"
        }
      ]
    },
